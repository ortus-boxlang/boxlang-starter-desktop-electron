{
	"name": "boxlang-starter-electron",
	"version": "1.0.0",
	"type": "module",
	"description": "A starter BoxLang application for building desktop applications with Electron",
	"main": "electron/main.js",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"dev:electron": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron-forge start\"",
		"prod": "npm run build && electron-forge start",
		"start": "electron-forge start",
		"test": "echo \"Error: no test specified\" && exit 1",
		"package": "npm run build && electron-forge package",
		"make": "npm run build && electron-forge make",
		"lint:fix": "eslint --ext .js,.ts . --fix",
		"lint:check": "eslint --ext .js,.ts ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"@electron-forge/cli": "^7.8.3",
		"concurrently": "^8.2.2",
		"cross-env": "^10.0.0",
		"electron": "^38.0.0",
		"eslint": "^8.0.0",
		"sass": "^1.77.0",
		"vite": "^7.1.4",
		"wait-on": "^7.2.0"
	}
}