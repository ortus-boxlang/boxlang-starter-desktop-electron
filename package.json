{
	"name": "boxlang-starter-electron",
	"version": "1.0.0",
	"type": "module",
	"description": "A starter BoxLang application for building desktop applications with Electron",
	"main": ".electron/main.js",
	"scripts": {
		"dev": "concurrently --kill-others \"npm run dev:vite\" \"npm run electron:delay\"",
		"dev:vite": "vite",
		"dev:electron": "concurrently \"npm run dev:vite\" \"wait-on http://127.0.0.1:3000 && npm run electron\"",
		"electron:delay": "sleep 3 && npm run electron:dev",
		"build": "vite build",
		"lint:fix": "eslint --ext .js,.ts . --fix",
		"lint:check": "eslint --ext .js,.ts .",
		"electron": "npx electron .electron/main.js",
		"electron:dev": "cross-env NODE_ENV=development npx electron .electron/main.js",
		"prod": "npm run build && npx electron .electron/main.js",
		"make": "npm run build && electron-builder",
		"package": "npm run build && electron-builder",
		"preview": "vite preview",
		"start": "npm run electron:dev"
	},
	"keywords": [],
	"author": "YOU",
	"license": "Apache-2.0",
	"devDependencies": {
		"concurrently": "^8.2.2",
		"cross-env": "^10.0.0",
		"electron": "^38.0.0",
		"electron-builder": "^24.13.3",
		"eslint": "^8.0.0",
		"sass": "^1.77.0",
		"vite": "^7.1.4",
		"wait-on": "^7.2.0"
	},
	"build": {
		"productName": "BoxLang Starter Desktop",
		"appId": "io.boxlang.starter",
		"mac": {
			"icon": "includes/icon.icns",
			"target": "dmg"
		},
		"win": {
			"icon": "includes/icon.ico",
			"target": "nsis"
		},
		"linux": {
			"icon": "includes/icon.iconset/icon.png",
			"target": "AppImage"
		}
	}
}