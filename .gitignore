# General Ignores + IDE
.DS_Store
settings.xml
WEB-INF

# BoxLang Home — runtime data (classes, logs, seed) only; config lives in .boxlang.json
.boxlang/classes/**
.boxlang/logs/**
# Seed is never in source, so each desktop app is secure
.boxlang/config/.seed

# MiniServer runtime home (logs, compiled classes, etc.)
.miniserver/home/

# Engines + Database + CBFS + Secrets
.env
.engine/**
.cbfs/**
.database/**

# logs + tests
logs/**
tests/results/**

# npm
**/node_modules/*
npm-debug.log
yarn-error.log

## Ignored Dependencies
coldbox/**
testbox/**
modules/**
boxlang_modules/**

# Ignore dist folder
dist/**

# Vite specific
.vite/
out/
includes/resources/**

# MiniServer packaging (exclude downloaded binaries)
.miniserver/bin/
.miniserver/lib/
.miniserver/VERSION
.miniserver/*.zip

# Electron build artifacts
*.app
*.dmg
*.pkg
*.exe
*.msi
*.deb
*.rpm
*.tar.gz
*.zip
