{
	"name": "boxlang-starter-electron",
	"version": "1.0.0",
	"type": "module",
	"description": "A starter BoxLang application for building desktop applications with Electron",
	"main": "app/electron/Main.js",
	"scripts": {
		"dev": "concurrently --kill-others \"vite\" \"wait-on tcp:127.0.0.1:3000 && cross-env NODE_ENV=development electron app/electron/Main.js\"",
		"build": "vite build",
		"start": "cross-env NODE_ENV=development electron app/electron/Main.js",
		"prod": "npm run build && electron app/electron/Main.js",
		"package": "npm run build && electron-builder",
		"package:miniserver": "boxlang runtime/Package.bx",
		"package:miniserver:force": "boxlang runtime/Package.bx --force",
		"package:full": "npm run package:miniserver && npm run package",
		"preview": "vite preview",
		"lint": "eslint --ext .js,.ts .",
		"lint:fix": "eslint --ext .js,.ts . --fix",
		"generate:icons": "node scripts/generate-icons.js"
	},
	"keywords": [],
	"author": "YOU",
	"dependencies": {
		"alpinejs": "^3.14.0",
		"bootstrap": "^5.3.0"
	},
	"devDependencies": {
		"concurrently": "^8.2.2",
		"cross-env": "^10.0.0",
		"electron": "^38.0.0",
		"electron-builder": "^24.13.3",
		"eslint": "^8.0.0",
		"sass": "^1.77.0",
		"vite": "^7.1.4",
		"png-to-ico": "^2.1.8",
		"wait-on": "^7.2.0"
	},
	"build": {
		"productName": "BoxLang Starter Desktop",
		"appId": "io.boxlang.starter",
		"asar": true,
		"asarUnpack": [
			"runtime/**"
		],
		"directories": {
			"output": "dist/electron"
		},
		"files": [
			"**/*",
			"!**/node_modules/**",
			"!dist/electron/**",
			"!resources/assets/**",
			"!.agents/**",
			"!.boxlang/**",
			"!.claude/**",
			"!.github/**",
			"!.vscode/**",
			"tests/**"
		],
		"mac": {
			"icon": "public/includes/icon.icns",
			"target": "dmg"
		},
		"win": {
			"icon": "public/includes/icon.ico",
			"target": "nsis"
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true
		},
		"linux": {
			"icon": "public/includes/icon.iconset/icon.png",
			"target": "AppImage",
			"category": "Utility"
		}
	}
}