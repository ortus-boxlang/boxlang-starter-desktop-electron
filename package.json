{
	"name": "boxlang-starter-electron",
	"version": "1.0.0",
	"type": "module",
	"description": "A starter BoxLang application for building desktop applications with Electron",
	"main": ".electron/main.js",
	"scripts": {
		"dev": "concurrently \"vite\" \"wait-on http://127.0.0.1:3000 && electron .electron/main.js\"",
		"dev:vite": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"dev:electron": "concurrently \"npm run dev:vite\" \"wait-on http://127.0.0.1:3000 && npm run electron\"",
		"electron": "electron .electron/main.js",
		"electron:dev": "cross-env NODE_ENV=development electron electron/main.js",
		"prod": "npm run build && electron electron/main.js",
		"start": "npm run electron:dev",
		"test": "echo \"Error: no test specified\" && exit 1",
		"package": "npm run build && electron-builder",
		"make": "npm run build && electron-builder",
		"lint:fix": "eslint --ext .js,.ts . --fix",
		"lint:check": "eslint --ext .js,.ts ."
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"devDependencies": {
		"concurrently": "^8.2.2",
		"cross-env": "^10.0.0",
		"electron": "^38.0.0",
		"electron-builder": "^24.13.3",
		"eslint": "^8.0.0",
		"sass": "^1.77.0",
		"vite": "^7.1.4",
		"wait-on": "^7.2.0"
	}
}